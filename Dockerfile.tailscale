FROM tewi:latest

RUN apt-get update && apt-get install -y \
    curl \
    && curl -fsSL https://tailscale.com/install.sh | sh \
    && rm -rf /var/lib/apt/lists/*

EXPOSE 3000 41641/udp

CMD ["sh", "-c", "tailscaled --state=/var/lib/tailscale/tailscaled.state & sleep 2 && tailscale up --authkey=${TAILSCALE_AUTHKEY} && ./tewi"]
